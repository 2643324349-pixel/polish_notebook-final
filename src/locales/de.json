  "tutorial": {
    "title": "Anleitung",
    "subtitle": "PolishMate in 6 Schritten starten",
    "prev": "Zurück",
    "next": "Weiter",
    "steps": {
      "1": {
        "title": "Erstes Heft erstellen",
        "description": "Erstellen Sie ein Heft, um Ihren Wortschatz zu organisieren. Geben Sie ihm einen Namen und wählen Sie eine Farbe, damit Sie es später leicht wiederfinden."
      },
      "2": {
        "title": "Grammatikformen per Klick generieren",
        "description": "Fügen Sie eine Seite hinzu, wählen Sie die gewünschten Grammatikformen und geben Sie eine beliebige Wortform ein. Klicken Sie dann auf ✨ Generate. PolishMate findet automatisch die Grundform und füllt die vollständige Grammatiktabelle und Übersetzung aus. KI-Inhalte tragen ein „AI“-Badge."
      },
      "3": {
        "title": "Lernen mit Ein- und Ausblenden",
        "description": "Blenden Sie Antworten aus, um sich selbst zu testen, und zeigen Sie sie an, wenn Sie bereit sind. So üben Sie Vokabeln und Grammatik direkt im Heft."
      },
      "4": {
        "title": "Suchen, Markieren & Exportieren",
        "description": "Finden Sie Wörter schnell, markieren Sie wichtige Einträge farbig und exportieren Sie Ihr Heft als Excel-Tabelle oder PNG-Bild zum Drucken, Teilen oder Sichern."
      },
      "5": {
        "title": "Geräteübergreifende Synchronisation",
        "description": "Ihre Hefte werden automatisch gespeichert und zwischen Smartphone und Webbrowser synchronisiert. Lernen Sie jederzeit und überall weiter. Weblink: https://polishmate.quickdart.app"
      },
      "6": {
        "title": "PolishMate in Ihrer Sprache nutzen",
        "description": "Wechseln Sie jederzeit die Oberflächensprache. Menüs, Spaltennamen und Übersetzungen werden für neu hinzugefügte Wörter automatisch aktualisiert. Bestehende Notizen müssen in der neuen Sprache neu generiert werden."
      }
    }
  },
