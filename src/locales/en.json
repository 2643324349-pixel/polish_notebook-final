  "tutorial": {
    "title": "Tutorial",
    "subtitle": "Get started with PolishMate in 6 steps",
    "prev": "Previous",
    "next": "Next",
    "steps": {
      "1": {
        "title": "Create Your First Notebook",
        "description": "Create a notebook to organize your vocabulary. Give it a name and choose a color so you can easily find it later."
      },
      "2": {
        "title": "Generate Grammar Forms in One Click",
        "description": "Add a page, choose the grammar forms you want, then enter any form of a word and click ✨ Generate. PolishMate automatically finds the base word and fills in the complete grammar table and translation. AI-filled content shows an \"AI\" badge."
      },
      "3": {
        "title": "Study with Hide & Reveal ",
        "description": "Hide answers to test yourself, then reveal them when you're ready. It's a simple way to practice vocabulary and grammar without leaving your notebook."
      },
      "4": {
        "title": "Search, Highlight & Export",
        "description": "Quickly find words, highlight important entries with colors, and export your notebook as an Excel spreadsheet or PNG image for printing, sharing, or backup."
      },
      "5": {
        "title": "Sync Across Devices",
        "description": "Your notebooks are automatically saved and synced across your phone and web browser. Continue learning anytime, anywhere. Website link: https://polishmate.quickdart.app"
      },
      "6": {
        "title": "Use PolishMate in Your Language",
        "description": "Switch the interface language anytime. Menus, table headers, and translations update automatically for newly added words. Existing notes need to be re-generated in the new language."
      }
    }
  },
