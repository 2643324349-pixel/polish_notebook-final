# Inflection API base URL (leave empty to use Vite dev proxy in local dev)
VITE_INFLECTION_API_URL=https://polish-notebook-final.onrender.com

# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase admin — backend only (inflection-server), never expose to frontend
SUPABASE_SERVICE_ROLE_KEY=

# Alibaba Qwen (DashScope) — used by scripts/build_tagged_gloss.py
# DASHSCOPE_API_KEY=sk-...

# Alibaba Qwen Singapore — runtime AI fallback (inflection-server)
QWEN_SINGAPORE_API_KEY=
QWEN_SINGAPORE_WORKSPACE_ID=
QWEN_SINGAPORE_BASE_URL=
# QWEN_SINGAPORE_MODEL=qwen-flash

# Legacy AI fallback aliases (optional if QWEN_SINGAPORE_* is set)
# INFLECTION_AI_API_KEY=
# INFLECTION_AI_BASE_URL=https://api.openai.com/v1
# INFLECTION_AI_MODEL=gpt-4o-mini
